# 本项目专用 venv（推荐复制或 python -m venv .venv 后安装依赖）
WATERMARK_STRIP_PYTHON=.venv\Scripts\python.exe

# HuggingFace 模型缓存（SDXL + ControlNet 约 26GB，建议放 D 盘）
HF_HOME=D:\huggingface
HF_HUB_CACHE=D:\huggingface\hub
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# HTTP 服务端口
WATERMARK_STRIP_PORT=8787

# 穿透暴露时必填；留空则仅允许本机访问（不校验 Key）
WATERMARK_STRIP_API_KEY=

# cuda | cpu（默认自动检测，有 NVIDIA 时用 cuda）
WATERMARK_STRIP_DEVICE=cuda

# 扩散长边上限，1536 对齐 maternal/crypto 出图
WATERMARK_STRIP_MAX_RESOLUTION=1536

# 启动时预加载 SDXL+ControlNet 到显存（1=开启，远端定时调用推荐开启）
WATERMARK_STRIP_PRELOAD=1

# 预加载 / 批量处理最长等待秒数（模型进显存约 1–3 分钟）
WATERMARK_STRIP_WARM_TIMEOUT=900

# controlnet | sdxl
WATERMARK_STRIP_PIPELINE=controlnet

# 默认 mode：all | invisible | visible | metadata
WATERMARK_STRIP_DEFAULT_MODE=all
# 扩散步数（默认 50；可试 40 略快）
WATERMARK_STRIP_STEPS=50
# GenerateImage（OpenAI）建议 0.20；清洗后 JPEG 无 C2PA 时勿留空（否则 unknown→0.30）
WATERMARK_STRIP_STRENGTH=0.20
# 与官方 CLI 一致：扩散后自适应锐化（默认开）
WATERMARK_STRIP_ADAPTIVE_POLISH=1
# 平涂区双边降噪，减轻字块白点（默认开，仅 all/invisible 后）
WATERMARK_STRIP_POST_DENOISE=1
WATERMARK_STRIP_DENOISE_SIGMA=40
WATERMARK_STRIP_DENOISE_D=9
